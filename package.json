{
  "name": "create-h3ravel",
  "type": "module",
  "version": "2.1.2",
  "description": "Scaffold a new H3ravel applications using templates and starter kits",
  "main": "build/index.js",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "create-h3ravel": "bin/run.js"
  },
  "exports": {
    ".": "./bin/run.js"
  },
  "keywords": [
    "h3ravel",
    "create-h3ravel"
  ],
  "scripts": {
    "quick:test": "pnpm vitest",
    "test": "pnpm run quick:test",
    "runner": "pnpm build && node bin/run.mjs",
    "build": "tsdown",
    "version": "pnpm run build",
    "unlink": "npm unlink -g create-h3ravel",
    "release": "pnpm build && pnpm changeset version && pnpm changeset publish",
    "publish-it": "pnpm build && pnpm publish --tag latest"
  },
  "files": [
    "bin",
    "bin/run.d.ts",
    "bin/run.js"
  ],
  "dependencies": {
    "@antfu/install-pkg": "1.1.0",
    "@h3ravel/collect.js": "^5.3.7",
    "@h3ravel/musket": "^2.0.0",
    "@h3ravel/shared": "^2.1.2",
    "@h3ravel/support": "^2.1.2",
    "@inquirer/core": "^10.2.2",
    "giget": "^2.0.0",
    "inquirer": "^12.9.6",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.41",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "ts-node": "^10.9.2",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.14.0"
}